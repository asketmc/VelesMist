{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/asketmc/VelesMist/schemas/price-cache.v1.json",
  "title": "VelesMist price cache v1",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "currency",
    "prices"
  ],
  "properties": {
    "schema_version": {
      "const": "velesmist.price-cache.v1",
      "description": "Required schema marker. Unsupported schema versions fail as invalid input."
    },
    "currency": {
      "type": "string",
      "minLength": 3,
      "description": "Currency label used for local/manual prices and report output."
    },
    "prices": {
      "type": "object",
      "description": "Object keyed by Steam market_hash_name. Missing item keys produce missing_price scan rows.",
      "propertyNames": {
        "minLength": 1
      },
      "additionalProperties": {
        "$ref": "#/$defs/price"
      }
    }
  },
  "$defs": {
    "price": {
      "type": "object",
      "additionalProperties": false,
      "anyOf": [
        {
          "required": [
            "buyer_price_cents"
          ]
        },
        {
          "required": [
            "lowest_price"
          ]
        },
        {
          "required": [
            "median_price"
          ]
        }
      ],
      "properties": {
        "buyer_price_cents": {
          "type": "integer",
          "minimum": 1,
          "description": "Gross buyer-facing price in cents."
        },
        "lowest_price": {
          "type": "string",
          "minLength": 1
        },
        "median_price": {
          "type": "string",
          "minLength": 1
        },
        "source": {
          "type": "string"
        },
        "confidence": {
          "enum": [
            "medium",
            "none"
          ],
          "description": "Optional confidence metadata for future or external tooling. The current scorer treats local cache prices as medium confidence and missing prices as none."
        },
        "liquidity_score": {
          "type": "integer",
          "minimum": 0,
          "description": "Optional liquidity metadata for future or external tooling. The current scorer emits 0 because live liquidity is not implemented."
        }
      }
    }
  }
}
