{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/asketmc/VelesMist/schemas/scan-report.v1.json",
  "title": "VelesMist scan report v1",
  "description": "Stable JSON output contract for VelesMist scan reports. Items are sorted by recommendation priority, then total seller receive, buyer price, count, and market_hash_name.",
  "$comment": "Recommendation sorting order is sell, skip, missing_price. The planned/not-yet-implemented recommendation value not_marketable is reserved for a future contract update and is documented here without being accepted by scan-report.v1 validation. Unpriced items use price_status=missing and recommendation=missing_price.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "generated_at",
    "steam_id",
    "appid",
    "contextid",
    "currency",
    "threshold_cents",
    "items",
    "candidates",
    "summary"
  ],
  "properties": {
    "schema_version": {
      "const": "velesmist.scan.v1"
    },
    "generated_at": {
      "type": "string",
      "format": "date-time"
    },
    "steam_id": {
      "type": "string"
    },
    "appid": {
      "type": "integer",
      "minimum": 1
    },
    "contextid": {
      "type": "string"
    },
    "currency": {
      "type": "string",
      "minLength": 3,
      "description": "Currency label for monetary fields. VelesMist does not convert currencies in scan-report.v1; values reflect the selected/local price cache currency."
    },
    "threshold_cents": {
      "type": "integer",
      "minimum": 0
    },
    "items": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/item"
      }
    },
    "candidates": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/item"
      }
    },
    "summary": {
      "$ref": "#/$defs/summary"
    }
  },
  "$defs": {
    "item": {
      "type": "object",
      "description": "A report item identity is appid, name, market_hash_name, count, tradable, and market_url. market_hash_name is the stable key used for local price-cache lookup.",
      "additionalProperties": false,
      "required": [
        "appid",
        "name",
        "market_hash_name",
        "count",
        "tradable",
        "market_url",
        "price_status",
        "liquidity_score",
        "confidence",
        "recommendation",
        "reason_codes",
        "candidate"
      ],
      "properties": {
        "appid": {
          "type": "integer",
          "minimum": 1
        },
        "name": {
          "type": "string",
          "minLength": 1
        },
        "market_hash_name": {
          "type": "string",
          "minLength": 1,
          "description": "Steam market hash name used as the item identity for pricing and market URLs."
        },
        "count": {
          "type": "integer",
          "minimum": 1
        },
        "tradable": {
          "type": "boolean"
        },
        "market_url": {
          "type": "string",
          "format": "uri",
          "description": "Steam Community Market URL derived from appid and market_hash_name."
        },
        "price_status": {
          "description": "missing means no local price cache entry was found for market_hash_name.",
          "enum": [
            "priced",
            "missing"
          ]
        },
        "buyer_price_cents": {
          "type": "integer",
          "minimum": 1,
          "description": "Gross buyer-facing price in cents."
        },
        "estimated_fee_cents": {
          "type": "integer",
          "minimum": 0,
          "description": "Estimated platform fee for one item in cents."
        },
        "seller_receive_cents": {
          "type": "integer",
          "minimum": 0,
          "description": "Estimated seller receive for one item in cents."
        },
        "total_buyer_price_cents": {
          "type": "integer",
          "minimum": 1
        },
        "total_estimated_fee_cents": {
          "type": "integer",
          "minimum": 0
        },
        "total_receive_cents": {
          "type": "integer",
          "minimum": 0
        },
        "price_source": {
          "type": "string"
        },
        "liquidity_score": {
          "type": "integer",
          "minimum": 0
        },
        "confidence": {
          "enum": [
            "medium",
            "none"
          ]
        },
        "recommendation": {
          "$comment": "Current emitted values are sell, skip, and missing_price. not_marketable is a planned/not-yet-implemented value and is intentionally not accepted by scan-report.v1 contract tests yet.",
          "enum": [
            "sell",
            "skip",
            "missing_price"
          ]
        },
        "reason_codes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "candidate": {
          "type": "boolean"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "price_status": {
                "const": "priced"
              }
            },
            "required": [
              "price_status"
            ]
          },
          "then": {
            "required": [
              "buyer_price_cents",
              "estimated_fee_cents",
              "seller_receive_cents",
              "total_buyer_price_cents",
              "total_estimated_fee_cents",
              "total_receive_cents",
              "price_source"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "price_status": {
                "const": "missing"
              }
            },
            "required": [
              "price_status"
            ]
          },
          "then": {
            "properties": {
              "recommendation": {
                "const": "missing_price"
              },
              "confidence": {
                "const": "none"
              },
              "candidate": {
                "const": false
              }
            },
            "not": {
              "anyOf": [
                {
                  "required": [
                    "buyer_price_cents"
                  ]
                },
                {
                  "required": [
                    "estimated_fee_cents"
                  ]
                },
                {
                  "required": [
                    "seller_receive_cents"
                  ]
                },
                {
                  "required": [
                    "total_buyer_price_cents"
                  ]
                },
                {
                  "required": [
                    "total_estimated_fee_cents"
                  ]
                },
                {
                  "required": [
                    "total_receive_cents"
                  ]
                },
                {
                  "required": [
                    "price_source"
                  ]
                }
              ]
            }
          }
        },
        {
          "if": {
            "properties": {
              "recommendation": {
                "const": "sell"
              }
            },
            "required": [
              "recommendation"
            ]
          },
          "then": {
            "properties": {
              "price_status": {
                "const": "priced"
              },
              "candidate": {
                "const": true
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "recommendation": {
                "const": "skip"
              }
            },
            "required": [
              "recommendation"
            ]
          },
          "then": {
            "properties": {
              "price_status": {
                "const": "priced"
              },
              "candidate": {
                "const": false
              }
            }
          }
        },
        {
          "if": {
            "properties": {
              "recommendation": {
                "const": "missing_price"
              }
            },
            "required": [
              "recommendation"
            ]
          },
          "then": {
            "properties": {
              "price_status": {
                "const": "missing"
              },
              "confidence": {
                "const": "none"
              },
              "candidate": {
                "const": false
              }
            }
          }
        }
      ]
    },
    "summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "marketable_items",
        "priced_items",
        "missing_price_items",
        "skipped_items",
        "candidate_items",
        "estimated_total_gross_cents",
        "estimated_total_fee_cents",
        "estimated_total_receive_cents"
      ],
      "properties": {
        "marketable_items": {
          "type": "integer",
          "minimum": 0
        },
        "priced_items": {
          "type": "integer",
          "minimum": 0
        },
        "missing_price_items": {
          "type": "integer",
          "minimum": 0
        },
        "skipped_items": {
          "type": "integer",
          "minimum": 0
        },
        "candidate_items": {
          "type": "integer",
          "minimum": 0
        },
        "estimated_total_gross_cents": {
          "type": "integer",
          "minimum": 0
        },
        "estimated_total_fee_cents": {
          "type": "integer",
          "minimum": 0
        },
        "estimated_total_receive_cents": {
          "type": "integer",
          "minimum": 0
        }
      }
    }
  }
}
